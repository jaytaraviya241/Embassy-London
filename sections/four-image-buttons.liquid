<section class="section-{{ section.id }} four-image-buttons">
  {%- if section.settings.heading != blank -%}
    <div class="page-width">
      <h2 class="four-image-buttons__heading">
        {{ section.settings.heading }}
      </h2>
    </div>
  {%- endif -%}

  <div class="four-image-buttons__grid">
    {%- for block in section.blocks -%}
      <div class="four-image-buttons__item">
        <div class="four-image-buttons__image-wrapper">
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 1200 }}"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              class="four-image-buttons__image"
            >
          {%- endif -%}

          {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
            <a
              href="{{ block.settings.button_link }}"
              class="button four-image-buttons__button-overlay"
            >
              {{ block.settings.button_label }}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Four image buttons",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop by category"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Four image buttons",
      "blocks": [{ "type": "column" }, { "type": "column" }, { "type": "column" }, { "type": "column" }]
    }
  ]
}
{% endschema %}

{% style %}
  .section-{{ section.id }}.four-image-buttons {
    margin-bottom: 40px;
  }

  .section-{{ section.id }} .four-image-buttons__heading {
    text-align: center;
    margin-bottom: 2rem;
  }

  /* Four images in a grid */
  .section-{{ section.id }} .four-image-buttons__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    column-gap: 0.8rem;
    width: 100%;
  }

  .section-{{ section.id }} .four-image-buttons__item {
    position: relative;
  }

  /* Image wrapper */
  .section-{{ section.id }} .four-image-buttons__image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  /* Image fills its cell */
  .section-{{ section.id }} .four-image-buttons__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .section-{{ section.id }} .four-image-buttons__item:hover .four-image-buttons__image {
    transform: scale(1.03);
  }

  /* Button inside image, bottom center */
  .section-{{ section.id }} .four-image-buttons__button-overlay {
    position: absolute;
    left: 50%;
    bottom: 2rem;
    font-size: 1.4rem;
    text-align: center;
    transform: translateX(-50%);
    background-color: #ffffff;
    color: #000000;
  }

  .section-{{ section.id }} .four-image-buttons__button-overlay:hover {
    background-color:rgb(101, 101, 101);
    color:rgb(255, 255, 255);
    border-color: #000000;
  }

  /* Tablet: 2x2 grid */
  @media screen and (max-width: 989px) {
    .section-{{ section.id }} .four-image-buttons__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Mobile: 1 per row */
  @media screen and (max-width: 749px) {
    .section-{{ section.id }} .four-image-buttons__grid {
      grid-template-columns: 1fr;
      column-gap: 0;
    }
  }
  /* Desktop / tablet: normal 4‑column grid (already set above)
     Mobile: turn into horizontal carousel */
  @media screen and (max-width: 749px) {
    .section-{{ section.id }} .four-image-buttons__grid {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: 1rem;
      padding: 0 1.5rem;            /* side padding for peek; adjust if needed */
    }

    .section-{{ section.id }} .four-image-buttons__item {
      flex: 0 0 80%;                /* width of each slide; try 80–100% */
      scroll-snap-align: start;
    }
  }
{% endstyle %}
