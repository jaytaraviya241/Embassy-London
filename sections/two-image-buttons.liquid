<section class="section-{{ section.id }} two-image-buttons">
  {%- if section.settings.heading != blank -%}
    <div class="page-width">
      <h2 class="two-image-buttons__heading">
        {{ section.settings.heading }}
      </h2>
    </div>
  {%- endif -%}

  <div class="two-image-buttons__grid">
    {%- for block in section.blocks -%}
      <div class="two-image-buttons__item">
        <div class="two-image-buttons__image-wrapper">
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 1600 }}"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              class="two-image-buttons__image"
            >
          {%- endif -%}

          {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
            <a
              href="{{ block.settings.button_link }}"
              class="button two-image-buttons__button-overlay"
            >
              {{ block.settings.button_label }}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Two image buttons",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop by category"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "max_blocks": 2,
  "presets": [
    {
      "name": "Two split images with buttons",
      "blocks": [{ "type": "column" }, { "type": "column" }]
    }
  ]
}
{% endschema %}

{% style %}
    .section-{{ section.id }} .two-image-buttons__heading {
      text-align: center;
      margin-bottom: 2rem;
    }

    /* Two images, space in middle, full width in section */
    .section-{{ section.id }} .two-image-buttons__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      column-gap: 1.5rem;
      width: 100%;
    }
    .section-{{ section.id }}.two-image-buttons {
      margin-bottom: 40px;
    }


    .section-{{ section.id }} .two-image-buttons__item {
      position: relative;
    }

    /* Image wrapper */
    .section-{{ section.id }} .two-image-buttons__image-wrapper {
      position: relative;
      width: 100%;
      height: 100%;
      overflow: hidden;
    }

    /* Image fills its half */
    .section-{{ section.id }} .two-image-buttons__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.4s ease;
    }

    .section-{{ section.id }} .two-image-buttons__item:hover .two-image-buttons__image {
      transform: scale(1.03);
    }

    /* Button inside image, bottom center */
    .section-{{ section.id }} .two-image-buttons__button-overlay {
      position: absolute;
      left: 50%;
      bottom: 5rem;
      transform: translateX(-50%);
    }

    /* Mobile: stack images */
    @media screen and (max-width: 749px) {
      .section-{{ section.id }} .two-image-buttons__grid {
        grid-template-columns: 1fr;
        column-gap: 0;
      }
    }

    /* White button with black text, light grey on hover */
  .section-{{ section.id }} .two-image-buttons__button-overlay {
    background-color: #ffffff;
    color: #000000;
    border: 1px solid #000000;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .section-{{ section.id }} .two-image-buttons__button-overlay:hover {
    background-color:rgb(101, 101, 101);  /* light grey */
    color:rgb(255, 255, 255);
    border-color: #000000;
  }
{% endstyle %}
